# Production environment template for JeevanSetu backend
PROJECT_NAME="Golden Minute AI"
API_STR="/api"
SECRET_KEY="change-this-to-a-long-random-production-secret"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
DEFAULT_USER_ROLE="user"
ADMIN_ROLES="admin,gov"
BACKEND_CORS_ORIGINS="https://your-domain.example"

DATABASE_URL="postgresql+asyncpg://postgres:change-me@your-postgres-host:5432/golden_minute"
REDIS_URL="redis://your-redis-host:6379/0"

FIREBASE_CREDENTIALS_PATH="/workspace/firebase-key.json"
SEED_DEFAULT_DATA=true

MODEL_PATH="/workspace/app/ai/model.joblib"